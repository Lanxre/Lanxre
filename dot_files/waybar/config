[
  {
    "layer": "top",
    "position": "top",

    "margin-top": 3,
    "margin-bottom": 3,
    "margin-left": 6,
    "margin-right": 6,

    "modules-left": [
      "hyprland/workspaces",
      "mpris"
    ],

    "modules-center": [
      "clock"
    ],

    "modules-right": [
      "hyprland/language",
      "network",
      "cpu",
      "memory",
      "disk",
      "pulseaudio",
      "tray",
      "custom/swaync",
      "custom/power"
    ],

    "hyprland/workspaces": {
      "all-outputs": false,
      "format": "{name}",
      "sort-by-number": true,
      "active-only": false,

      "on-scroll-up": "hyprctl dispatch workspace e+1 1>/dev/null",
      "on-scroll-down": "hyprctl dispatch workspace e-1 1>/dev/null",

      "persistent-workspaces": {
        "DP-2": [1, 5],
        "HDMI-A-1": [6, 10]
      }
    },

    "mpris": {
      "format": "{player_icon}  {artist} - {title}",
      "format-paused": "{status_icon}  {artist} - {title}",
      "tooltip-format": "{player} ({status})\r{artist} - {title}",
      "title-len": 20,

      "player-icons": {
        "default": "▶",
        "mpv": "",
        "spotify": "󰓇"
      },

      "status-icons": {
        "paused": "",
        "stopped": ""
      }
    },

    "hyprland/language": {
      "format": "{}",
      "format-ru": "🇷🇺",
      "format-en": "🇺🇸"
    },

    "network": {
      "format-wifi": "  {essid}",
      "format-ethernet": "󰈀  {ipaddr}",
      "format-disconnected": "󰖪  Offline",

      "tooltip-format": "{ifname} via {gwaddr}",
      "tooltip-format-wifi": "{essid}\n{signalStrength}%",

      "interval": 5
    },

    "clock": {
      "format": "{:%d.%m • %H:%M:%S}",
      "format-alt": "{:%A, %d %B %Y}",

      "interval": 1,

      "tooltip": true,

      "tooltip-format": "<span size='14pt'><b>{:%A, %d %B %Y}</b></span>\n\n<span font='JetBrainsMono Nerd Font 12'>{calendar}</span>",

      "calendar": {
        "mode": "month",
        "weeks-pos": "right",

        "format": {
          "months": "<span color='#cdd6f4'><b>{}</b></span>",
          "weekdays": "<span color='#f9e2af'><b>{}</b></span>",
          "weeks": "<span color='#89b4fa'><b>W{}</b></span>",
          "days": "<span color='#cdd6f4'>{}</span>",
          "today": "<span color='#f38ba8'><b>{}</b></span>"
        }
      }
    },

    "cpu": {
      "format": "  {usage}%",
      "interval": 1,
      "on-click": "tilix -e btop"
    },

    "memory": {
      "format": "  {}%",
      "interval": 1,
      "on-click": "tilix -e btop"
    },

    "disk": {
      "interval": 5,
      "format": "  {percentage_free}%"
    },

    "pulseaudio": {
      "format": "{icon}  <b>{volume}%</b>",
      "format-muted": "󰝟",
      "format-bluetooth": "{icon}   <b>{volume}%</b>",
      "format-bluetooth-muted": "󰝟 ",

      "format-icons": {
        "headset": "",
        "default": [
          "󰕿",
          "󰖀",
          "󰕾"
        ]
      },

      "tooltip": true,
      "on-click": "easyeffects"
    },

    "tray": {
      "icon-size": 15,
      "spacing": 10
    },

    "custom/swaync": {
      "tooltip": true,
      "format": "{icon}",
      "return-type": "json",

      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",

      "on-click": "sleep 0.1 && swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",

      "escape": true,

      "format-icons": {
        "notification": "<span foreground='red'><sup></sup></span>",
        "none": "",
        "dnd-notification": "<span foreground='red'><sup></sup></span>",
        "dnd-none": "",
        "inhibited-notification": "<span foreground='red'><sup></sup></span>",
        "inhibited-none": "",
        "dnd-inhibited-notification": "<span foreground='red'><sup></sup></span>",
        "dnd-inhibited-none": ""
      }
    },

    "custom/power": {
      "format": "",
      "tooltip": false,
      "on-click": "wlogout"
    }
  }
]